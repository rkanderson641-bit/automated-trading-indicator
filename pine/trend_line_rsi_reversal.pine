//@version=6
indicator("Trend Line RSI Reversal", overlay=true, max_lines_count=500, max_labels_count=500)

// ---------------------------------------------------------------------------
// Inputs
// ---------------------------------------------------------------------------
swingBars   = input.int(8, "Swing Lookback/Lookahead Bars", minval=1, group="Trend Structure")
rsiLen      = input.int(14, "RSI Length", minval=1, group="RSI")
rsiMaLen    = input.int(9, "RSI MA Length", minval=1, group="RSI")
overbought  = input.float(70, "Overbought (overextended)", group="RSI")
oversold    = input.float(30, "Oversold (underextended)", group="RSI")
bullColor   = input.color(color.green, "Bullish Trend Line Color", group="Style")
bearColor   = input.color(color.red, "Bearish Trend Line Color", group="Style")
showLabels  = input.bool(true, "Show signal/break labels", group="Style")
showDebug   = input.bool(false, "Show debug markers (structure break)", group="Debug")

// ---------------------------------------------------------------------------
// Trend direction uses a structure-break definition (same as
// reversal_confluence.pine): a close beyond the most recent prior swing
// high/low confirms a bullish/bearish trend immediately, without waiting
// for a pullback to form a second confirming pivot. Requiring two full
// higher-high/higher-low pivot pairs missed clean, sharp rallies entirely
// -- by the time a pullback formed the second confirming pivot, RSI's
// overbought peak had usually already passed.
//
// Once RSI confirms the trend is overextended/underextended (its MA above
// overbought during a confirmed uptrend, or below oversold during a
// confirmed downtrend), the trend line is drawn starting at the swing low
// (bullish) or swing high (bearish) that launched the move, through to
// the most recent confirming swing point. From there it keeps extending
// to each NEW confirming swing point as the trend continues, re-pivoting
// its slope, until price closes through its current projected value -- a
// trend break/reversal point.
// ---------------------------------------------------------------------------
pivotHighVal = ta.pivothigh(high, swingBars, swingBars)
pivotLowVal  = ta.pivotlow(low, swingBars, swingBars)
pivotBarIdx  = bar_index - swingBars

var float swingHigh1    = na
var float swingHigh2    = na
var int   swingHighBar1 = na
var int   swingHighBar2 = na
var float swingLow1     = na
var float swingLow2     = na
var int   swingLowBar1  = na
var int   swingLowBar2  = na

if not na(pivotHighVal)
    swingHigh1    := swingHigh2
    swingHighBar1 := swingHighBar2
    swingHigh2    := pivotHighVal
    swingHighBar2 := pivotBarIdx

if not na(pivotLowVal)
    swingLow1    := swingLow2
    swingLowBar1 := swingLowBar2
    swingLow2    := pivotLowVal
    swingLowBar2 := pivotBarIdx

// Structure break: price closes beyond the most recent prior swing
// high/low. Stays "armed" until the opposite break occurs.
var float breakLastHigh   = na
var float breakLastLow    = na
var bool  hadBullishBreak = false
var bool  hadBearishBreak = false

if not na(pivotHighVal)
    breakLastHigh := pivotHighVal

if not na(pivotLowVal)
    breakLastLow := pivotLowVal

bullishBreakNow = not na(breakLastHigh) and close > breakLastHigh
bearishBreakNow = not na(breakLastLow) and close < breakLastLow

if bullishBreakNow
    breakLastHigh    := close
    hadBullishBreak   := true
    hadBearishBreak   := false
    if showDebug
        label.new(bar_index, high, text="BREAK", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)

if bearishBreakNow
    breakLastLow      := close
    hadBearishBreak   := true
    hadBullishBreak    := false
    if showDebug
        label.new(bar_index, low, text="BREAK", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)

rsiVal = ta.rsi(close, rsiLen)
rsiMa  = ta.sma(rsiVal, rsiMaLen)

// "Armed" latches prevent re-firing every bar while RSI stays past the
// threshold, and reset once RSI comes back inside the bands.
var bool bullArmed = false
var bool bearArmed = false

if rsiMa <= overbought
    bullArmed := false
if rsiMa >= oversold
    bearArmed := false

bullTrigger = hadBullishBreak and rsiMa > overbought and not bullArmed
bearTrigger = hadBearishBreak and rsiMa < oversold and not bearArmed

if bullTrigger
    bullArmed := true
if bearTrigger
    bearArmed := true

var line  bullLine        = na
var bool  trackingBull     = false
var int   bullStartBar     = na
var float bullStartPrice   = na
var int   bullLastBar      = na
var float bullLastPrice    = na

var line  bearLine        = na
var bool  trackingBear     = false
var int   bearStartBar     = na
var float bearStartPrice   = na
var int   bearLastBar      = na
var float bearLastPrice    = na

if bullTrigger and not na(swingLowBar1)
    if not na(bullLine)
        line.delete(bullLine)
    // Anchor the second point at the CURRENT bar/price rather than the
    // older confirmed pivot -- using the pivot pair's slope projected
    // across the (potentially large) gap to the trigger bar could already
    // overshoot current price, causing an instant self-break before the
    // line was ever visible.
    bullStartBar   := swingLowBar1
    bullStartPrice := swingLow1
    bullLastBar    := bar_index
    bullLastPrice  := close
    bullLine       := line.new(bullStartBar, bullStartPrice, bullLastBar, bullLastPrice, extend=extend.right, color=bullColor, width=2)
    trackingBull   := true
    if showLabels
        label.new(bar_index, low, text="OVEREXTENDED", style=label.style_label_up, color=color.new(bullColor, 70), textcolor=color.white, size=size.small)

if bearTrigger and not na(swingHighBar1)
    if not na(bearLine)
        line.delete(bearLine)
    bearStartBar   := swingHighBar1
    bearStartPrice := swingHigh1
    bearLastBar    := bar_index
    bearLastPrice  := close
    bearLine       := line.new(bearStartBar, bearStartPrice, bearLastBar, bearLastPrice, extend=extend.right, color=bearColor, width=2)
    trackingBear   := true
    if showLabels
        label.new(bar_index, high, text="UNDEREXTENDED", style=label.style_label_down, color=color.new(bearColor, 70), textcolor=color.white, size=size.small)

// ---------------------------------------------------------------------------
// While still tracking, extend the line to each new confirming swing point
// in the same direction (re-pivoting its slope), then check for a break
// against the line's current projected value.
// ---------------------------------------------------------------------------
bullBreak = false
bearBreak = false

if trackingBull and not na(bullLine)
    if not na(pivotLowVal) and pivotLowVal > bullLastPrice
        bullLastBar   := pivotBarIdx
        bullLastPrice := pivotLowVal
        line.set_xy2(bullLine, bullLastBar, bullLastPrice)

    bullSlope     = (bullLastPrice - bullStartPrice) / (bullLastBar - bullStartBar)
    bullProjected = bullLastPrice + bullSlope * (bar_index - bullLastBar)
    if close < bullProjected
        bullBreak := true
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_down, color=color.new(color.red, 50), textcolor=color.white, size=size.small)
        line.delete(bullLine)
        bullLine     := na
        trackingBull := false

if trackingBear and not na(bearLine)
    if not na(pivotHighVal) and pivotHighVal < bearLastPrice
        bearLastBar   := pivotBarIdx
        bearLastPrice := pivotHighVal
        line.set_xy2(bearLine, bearLastBar, bearLastPrice)

    bearSlope     = (bearLastPrice - bearStartPrice) / (bearLastBar - bearStartBar)
    bearProjected = bearLastPrice + bearSlope * (bar_index - bearLastBar)
    if close > bearProjected
        bearBreak := true
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_up, color=color.new(color.green, 50), textcolor=color.white, size=size.small)
        line.delete(bearLine)
        bearLine     := na
        trackingBear := false

alertcondition(bullTrigger, title="Bullish Trend Overextended", message="Uptrend confirmed and RSI is overbought -- watch for reversal")
alertcondition(bearTrigger, title="Bearish Trend Underextended", message="Downtrend confirmed and RSI is oversold -- watch for reversal")
alertcondition(bullBreak, title="Bullish Trend Line Broken", message="Price closed below the overextended uptrend line")
alertcondition(bearBreak, title="Bearish Trend Line Broken", message="Price closed above the underextended downtrend line")
