//@version=6
indicator("Trend Line RSI Reversal", overlay=true, max_lines_count=500, max_labels_count=500)

// ---------------------------------------------------------------------------
// Inputs
// ---------------------------------------------------------------------------
swingBars        = input.int(8, "Swing Lookback/Lookahead Bars (trend direction)", minval=1, group="Trend Structure")
touchBars        = input.int(3, "Touch Point Lookback/Lookahead Bars (line anchors)", minval=1, group="Trend Structure")
atrLen           = input.int(14, "ATR Length", minval=1, group="Trend Structure")
minBreakAtrMult  = input.float(1.0, "Minimum break size (x ATR)", minval=0.1, step=0.1, group="Trend Structure")
divergeAtrMult   = input.float(0.5, "Divergence sensitivity margin (x ATR)", minval=0.0, step=0.1, group="Trend Structure")
rsiLen           = input.int(14, "RSI Length", minval=1, group="RSI")
rsiMaLen         = input.int(9, "RSI MA Length", minval=1, group="RSI")
overbought       = input.float(70, "Overbought (overextended)", group="RSI")
oversold         = input.float(30, "Oversold (underextended)", group="RSI")
bullColor        = input.color(color.green, "Bullish Trend Line Color", group="Style")
bearColor        = input.color(color.red, "Bearish Trend Line Color", group="Style")
bullDivergeColor = input.color(#80FF80, "Bullish Divergent Line Color", group="Style")
bearDivergeColor = input.color(#FF8080, "Bearish Divergent Line Color", group="Style")
showLabels       = input.bool(true, "Show signal/break labels", group="Style")
freezeExtendBars = input.int(6, "Extend a frozen line past its break point (bars)", minval=0, group="Style")
showDebug        = input.bool(true, "Show debug markers (structure break)", group="Debug")

// ---------------------------------------------------------------------------
// A bearish trend line connects swing HIGHS only -- never a high to a low.
// A bullish trend line connects swing LOWS only. Both points of a given
// line are always the same type of pivot, exactly like a hand-drawn
// descending-resistance or ascending-support line: origin = the highest
// high that started a downtrend leg / lowest low that started an uptrend
// leg, far point = the lowest high / highest low reached so far.
//
// Two separate pivot lookbacks are used. `swingBars` (larger, default 8)
// confirms overall trend DIRECTION and picks the origin pivot when a leg
// starts -- unchanged since that was never the problem. `touchBars`
// (smaller, default 3) finds the touch points used to roll the line's far
// point forward. A single wide lookback for both was too strict for minor
// bounces during a fast or choppy move -- a real lower-high/higher-low
// could go an entire leg without ever satisfying an 8-bar-both-sides
// window, leaving the far point stuck at the origin (a perfectly flat
// line) even though the candles clearly show descending highs / ascending
// lows the whole way.
//
// The far point rolls forward to each NEW confirmed same-type touch point
// that CONTINUES the structure (a lower high while bearish, a higher low
// while bullish). A touch point that fails to continue is simply not used
// -- it's ignored, the anchor stays exactly as it was. A touch point that
// DOES continue, but lands beyond where the established line already
// projects to that bar by more than a small ATR margin, means the trend
// has gotten steeper (diverged): the anchor resets to start a fresh,
// steeper line from that same point out to the new touch point. A trend
// can branch into more than one successive divergent line as price keeps
// over/underextending -- that's expected, not an error. Divergent
// branches are drawn in a separate, lighter color so they're easy to spot
// against the original line. A candidate divergent branch is only
// accepted if the straight line between its two points wouldn't cut into
// the BODY (open/close range) of any candle in between -- it may still
// touch a wick, just never a body. If it would, the touch point is
// treated as a normal continuation instead (no branch yet), deferring the
// branch until a touch point comes along where the geometry actually
// works.
//
// Once RSI confirms the trend is stretched and a line starts being drawn,
// it behaves exactly like auto_support_resistance.pine's level lines:
// every bar it extends forward to the current bar along its established
// slope, instead of sitting frozen at its last confirmed touch point. It
// only stops -- frozen in place, left on the chart permanently -- once
// price actually closes back through the LINE ITSELF (not some unrelated
// past pivot) by more than the break margin. Lines are never deleted.
//
// RSI's moving average lags price by design (it's a smoothed average), so
// it can cross into overbought/oversold a few bars AFTER the underlying
// structure break that defined the trend has already reversed. A strict
// same-bar "trend direction is live AND RSI is past threshold" check would
// silently miss a real overextension that the chart clearly shows just
// because the two conditions never lined up on the same bar. A short
// grace window (the RSI MA length) after a trend direction flips lets a
// pending RSI confirmation still complete using the anchor as it stood
// when that trend ended.
// ---------------------------------------------------------------------------

// Returns true if the straight line from (fromBar, fromPrice) to (toBar,
// toPrice) would cut into the open/close body of any bar strictly between
// the two -- touching a wick is fine, this only flags an actual body cut.
lineEntersBody(int fromBar, float fromPrice, int toBar, float toPrice) =>
    slope = toBar != fromBar ? (toPrice - fromPrice) / (toBar - fromBar) : 0.0
    entersBody = false
    if toBar - fromBar > 1
        for i = fromBar + 1 to toBar - 1
            offset = bar_index - i
            lineVal = fromPrice + slope * (i - fromBar)
            bodyTop = math.max(open[offset], close[offset])
            bodyBottom = math.min(open[offset], close[offset])
            if lineVal < bodyTop and lineVal > bodyBottom
                entersBody := true
    entersBody

pivotHighVal = ta.pivothigh(high, swingBars, swingBars)
pivotLowVal  = ta.pivotlow(low, swingBars, swingBars)
pivotBarIdx  = bar_index - swingBars

touchPivotHighVal = ta.pivothigh(high, touchBars, touchBars)
touchPivotLowVal  = ta.pivotlow(low, touchBars, touchBars)
touchPivotBarIdx  = bar_index - touchBars

var float lastPivotHigh    = na
var int   lastPivotHighBar = na
var float lastPivotLow     = na
var int   lastPivotLowBar  = na

if not na(pivotHighVal)
    lastPivotHigh    := pivotHighVal
    lastPivotHighBar := pivotBarIdx

if not na(pivotLowVal)
    lastPivotLow    := pivotLowVal
    lastPivotLowBar := pivotBarIdx

atrVal = ta.atr(atrLen)

var float breakLastHigh   = na
var float breakLastLow    = na
var bool  hadBullishBreak = false
var bool  hadBearishBreak = false

// breakLastHigh/breakLastLow always ratchet to the most recent confirmed
// pivot, regardless of current trend state -- used only to establish
// overall directional bias (which pivot type to anchor on, and RSI
// trigger eligibility), never to end an already-active line. Ending an
// active line is handled separately, below, against the line itself.
if not na(pivotHighVal)
    breakLastHigh := pivotHighVal
if not na(pivotLowVal)
    breakLastLow := pivotLowVal

bullishBreakNowRaw = not na(breakLastHigh) and close > breakLastHigh + atrVal * minBreakAtrMult
bearishBreakNowRaw = not na(breakLastLow) and close < breakLastLow - atrVal * minBreakAtrMult

// On a rare bar where price simultaneously clears both thresholds, only
// let ONE side fire so the two blocks can't fight over the shared
// hadBullishBreak/hadBearishBreak flags.
bullishBreakNow = bullishBreakNowRaw
bearishBreakNow = bearishBreakNowRaw and not bullishBreakNowRaw

var line bullLine = na
var line bearLine = na
var bool trackingBull = false
var bool trackingBear = false
var bool bullIsDivergent = false
var bool bearIsDivergent = false

var int   bullOriginBar   = na
var float bullOriginPrice = na
var int   bullFarBar      = na
var float bullFarPrice    = na

var int   bearOriginBar   = na
var float bearOriginPrice = na
var int   bearFarBar      = na
var float bearFarPrice    = na

var int bullGraceEndBar = na
var int bearGraceEndBar = na

bullBreak = false
bearBreak = false

if bullishBreakNow
    wasBearish      = hadBearishBreak
    freshBullStart  = not hadBullishBreak
    breakLastHigh   := close
    hadBullishBreak := true
    hadBearishBreak := false
    if wasBearish
        bearGraceEndBar := bar_index + rsiMaLen
    if showDebug
        label.new(bar_index, high, text="BREAK", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
    if freshBullStart
        bullOriginBar   := lastPivotLowBar
        bullOriginPrice := lastPivotLow
        bullFarBar      := bullOriginBar
        bullFarPrice    := bullOriginPrice
        bullIsDivergent := false
        // Forget (don't delete) the previous leg's line -- it stays on
        // the chart as permanent history of that completed leg.
        bullLine := na
        if showDebug
            label.new(bullOriginBar, bullOriginPrice, text="L", style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)

if bearishBreakNow
    wasBullish      = hadBullishBreak
    freshBearStart  = not hadBearishBreak
    breakLastLow    := close
    hadBearishBreak := true
    hadBullishBreak := false
    if wasBullish
        bullGraceEndBar := bar_index + rsiMaLen
    if showDebug
        label.new(bar_index, low, text="BREAK", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
    if freshBearStart
        bearOriginBar   := lastPivotHighBar
        bearOriginPrice := lastPivotHigh
        bearFarBar      := bearOriginBar
        bearFarPrice    := bearOriginPrice
        bearIsDivergent := false
        bearLine := na
        if showDebug
            label.new(bearOriginBar, bearOriginPrice, text="H", style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)

// Roll the far point forward on each new SAME-TYPE touch point that
// continues the structure (a lower high while bearish, a higher low while
// bullish). A touch point that fails to continue is simply ignored -- not
// a touch point, the anchor stays exactly as it was. A touch point that
// continues but overshoots the established line's own projection to that
// bar by more than the divergence margin means the trend has gotten
// steeper -- UNLESS the resulting line would cut into an intervening
// candle's body, in which case it's treated as a normal continuation
// instead and the branch is deferred to a later, cleaner touch point.
if hadBullishBreak and not na(touchPivotLowVal)
    if na(bullOriginBar)
        bullOriginBar   := touchPivotBarIdx
        bullOriginPrice := touchPivotLowVal
        bullFarBar      := bullOriginBar
        bullFarPrice    := bullOriginPrice
        bullIsDivergent := false
        if showDebug
            label.new(bullOriginBar, bullOriginPrice, text="L", style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if touchPivotLowVal > bullFarPrice
        bullEstSlope    = bullFarBar != bullOriginBar ? (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar) : 0.0
        bullProjected   = bullFarPrice + bullEstSlope * (touchPivotBarIdx - bullFarBar)
        bullDiverges    = bullFarBar != bullOriginBar and touchPivotLowVal > bullProjected + atrVal * divergeAtrMult
        bullBranchClean = not lineEntersBody(bullFarBar, bullFarPrice, touchPivotBarIdx, touchPivotLowVal)
        // A branch needs at least swingBars between its two points -- two
        // touch points just a handful of bars apart (e.g. bracketing one
        // huge spike candle) produce a slope so steep that continuous
        // extension shoots the line almost straight up/down within a few
        // bars. Without enough run, treat it as a normal continuation
        // instead and wait for a touch point with real separation.
        bullEnoughRun   = touchPivotBarIdx - bullFarBar >= swingBars
        if bullDiverges and bullBranchClean and bullEnoughRun
            bullLine        := na
            bullIsDivergent := true
            bullOriginBar   := bullFarBar
            bullOriginPrice := bullFarPrice
            bullFarBar      := touchPivotBarIdx
            bullFarPrice    := touchPivotLowVal
            if showDebug
                label.new(bullFarBar, bullFarPrice, text="D", style=label.style_circle, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
        else
            bullFarBar   := touchPivotBarIdx
            bullFarPrice := touchPivotLowVal
            if showDebug
                label.new(bullFarBar, bullFarPrice, text="+", style=label.style_circle, color=color.new(bullColor, 30), size=size.tiny)
    else
        if showDebug
            label.new(touchPivotBarIdx, touchPivotLowVal, text="x", style=label.style_circle, color=color.new(color.gray, 60), size=size.tiny)

if hadBearishBreak and not na(touchPivotHighVal)
    if na(bearOriginBar)
        bearOriginBar   := touchPivotBarIdx
        bearOriginPrice := touchPivotHighVal
        bearFarBar      := bearOriginBar
        bearFarPrice    := bearOriginPrice
        bearIsDivergent := false
        if showDebug
            label.new(bearOriginBar, bearOriginPrice, text="H", style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if touchPivotHighVal < bearFarPrice
        bearEstSlope    = bearFarBar != bearOriginBar ? (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar) : 0.0
        bearProjected   = bearFarPrice + bearEstSlope * (touchPivotBarIdx - bearFarBar)
        bearDiverges    = bearFarBar != bearOriginBar and touchPivotHighVal < bearProjected - atrVal * divergeAtrMult
        bearBranchClean = not lineEntersBody(bearFarBar, bearFarPrice, touchPivotBarIdx, touchPivotHighVal)
        // A branch needs at least swingBars between its two points -- two
        // touch points just a handful of bars apart (e.g. bracketing one
        // huge spike candle) produce a slope so steep that continuous
        // extension shoots the line almost straight up/down within a few
        // bars. Without enough run, treat it as a normal continuation
        // instead and wait for a touch point with real separation.
        bearEnoughRun   = touchPivotBarIdx - bearFarBar >= swingBars
        if bearDiverges and bearBranchClean and bearEnoughRun
            bearLine        := na
            bearIsDivergent := true
            bearOriginBar   := bearFarBar
            bearOriginPrice := bearFarPrice
            bearFarBar      := touchPivotBarIdx
            bearFarPrice    := touchPivotHighVal
            if showDebug
                label.new(bearFarBar, bearFarPrice, text="D", style=label.style_circle, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
        else
            bearFarBar   := touchPivotBarIdx
            bearFarPrice := touchPivotHighVal
            if showDebug
                label.new(bearFarBar, bearFarPrice, text="+", style=label.style_circle, color=color.new(bearColor, 30), size=size.tiny)
    else
        if showDebug
            label.new(touchPivotBarIdx, touchPivotHighVal, text="x", style=label.style_circle, color=color.new(color.gray, 60), size=size.tiny)

rsiVal = ta.rsi(close, rsiLen)
rsiMa  = ta.sma(rsiVal, rsiMaLen)

// "Armed" latches prevent re-firing every bar while RSI stays past the
// threshold, and reset once RSI comes back inside the bands.
var bool bullArmed = false
var bool bearArmed = false

if rsiMa <= overbought
    bullArmed := false
if rsiMa >= oversold
    bearArmed := false

// Fire if the trend is live right now, OR it just ended within the last
// rsiMaLen bars and RSI's lagging average is only now catching up to the
// extreme that happened during it (see comment block above).
bullTrigger = (hadBullishBreak or (not na(bullGraceEndBar) and bar_index <= bullGraceEndBar)) and not na(bullOriginBar) and rsiMa > overbought and not bullArmed
bearTrigger = (hadBearishBreak or (not na(bearGraceEndBar) and bar_index <= bearGraceEndBar)) and not na(bearOriginBar) and rsiMa < oversold and not bearArmed

if bullTrigger
    bullArmed    := true
    trackingBull := true
    if showLabels
        label.new(bar_index, low, text="OVEREXTENDED", style=label.style_label_up, color=color.new(bullColor, 70), textcolor=color.white, size=size.small)

if bearTrigger
    bearArmed    := true
    trackingBear := true
    if showLabels
        label.new(bar_index, high, text="UNDEREXTENDED", style=label.style_label_down, color=color.new(bearColor, 70), textcolor=color.white, size=size.small)

// Once a line is being tracked, extend it to the current bar along its
// established slope every single bar -- exactly like auto_support_
// resistance.pine's level lines -- instead of sitting frozen at its last
// confirmed touch point. It only stops, frozen in place permanently
// (never deleted), once price actually closes back through the LINE
// ITSELF by more than the break margin -- not some unrelated past pivot.
if trackingBull and not na(bullOriginBar)
    bullSlope        = bullFarBar != bullOriginBar ? (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar) : 0.0
    bullProjectedNow = bullFarPrice + bullSlope * (bar_index - bullFarBar)
    // A touch point only confirms touchBars after it actually happened,
    // so a freshly updated far point is always touchBars bars "stale"
    // versus bar_index. For a shallow line that's negligible, but a steep
    // (e.g. just-diverged) line can swing the projection by a lot over
    // those touchBars bars alone -- add a slope-proportional buffer so a
    // steep line isn't judged broken by an artifact of its own lag.
    bullBreakMargin  = atrVal * minBreakAtrMult + math.abs(bullSlope) * touchBars
    if close < bullProjectedNow - bullBreakMargin
        // Extend a touch past the actual break point before freezing, so
        // the finished line reads clearly instead of stopping dead.
        if not na(bullLine) and freezeExtendBars > 0
            line.set_xy2(bullLine, bar_index + freezeExtendBars, bullProjectedNow + bullSlope * freezeExtendBars)
        trackingBull    := false
        bullBreak       := true
        bullLine        := na
        bullOriginBar   := na
        bullOriginPrice := na
        bullFarBar      := na
        bullFarPrice    := na
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_down, color=color.new(color.red, 50), textcolor=color.white, size=size.small)
    else
        bullLineColor = bullIsDivergent ? bullDivergeColor : bullColor
        if na(bullLine)
            bullLine := line.new(bullOriginBar, bullOriginPrice, bar_index, bullProjectedNow, extend=extend.none, color=bullLineColor, width=2)
        else
            line.set_xy2(bullLine, bar_index, bullProjectedNow)

if trackingBear and not na(bearOriginBar)
    bearSlope        = bearFarBar != bearOriginBar ? (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar) : 0.0
    bearProjectedNow = bearFarPrice + bearSlope * (bar_index - bearFarBar)
    bearBreakMargin  = atrVal * minBreakAtrMult + math.abs(bearSlope) * touchBars
    if close > bearProjectedNow + bearBreakMargin
        if not na(bearLine) and freezeExtendBars > 0
            line.set_xy2(bearLine, bar_index + freezeExtendBars, bearProjectedNow + bearSlope * freezeExtendBars)
        trackingBear    := false
        bearBreak       := true
        bearLine        := na
        bearOriginBar   := na
        bearOriginPrice := na
        bearFarBar      := na
        bearFarPrice    := na
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_up, color=color.new(color.green, 50), textcolor=color.white, size=size.small)
    else
        bearLineColor = bearIsDivergent ? bearDivergeColor : bearColor
        if na(bearLine)
            bearLine := line.new(bearOriginBar, bearOriginPrice, bar_index, bearProjectedNow, extend=extend.none, color=bearLineColor, width=2)
        else
            line.set_xy2(bearLine, bar_index, bearProjectedNow)

// Live numeric readout of whichever line(s) are currently tracking --
// exact origin/far anchors and the resulting slope, so anchor placement
// can be verified precisely instead of estimated from chart pixels.
if showDebug and barstate.islast
    var table dbgTable = table.new(position.bottom_right, 2, 2, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)
    bullDbgSlope = trackingBull and not na(bullOriginBar) and bullFarBar != bullOriginBar ? (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar) : na
    bearDbgSlope = trackingBear and not na(bearOriginBar) and bearFarBar != bearOriginBar ? (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar) : na
    bullDbgText  = trackingBull and not na(bullOriginBar) ? "o(" + str.tostring(bullOriginBar) + ", " + str.tostring(bullOriginPrice, format.mintick) + ")  f(" + str.tostring(bullFarBar) + ", " + str.tostring(bullFarPrice, format.mintick) + ")  slope=" + str.tostring(bullDbgSlope, "#.####") + (bullIsDivergent ? "  [D]" : "") : "inactive"
    bearDbgText  = trackingBear and not na(bearOriginBar) ? "o(" + str.tostring(bearOriginBar) + ", " + str.tostring(bearOriginPrice, format.mintick) + ")  f(" + str.tostring(bearFarBar) + ", " + str.tostring(bearFarPrice, format.mintick) + ")  slope=" + str.tostring(bearDbgSlope, "#.####") + (bearIsDivergent ? "  [D]" : "") : "inactive"
    table.cell(dbgTable, 0, 0, "Bull", text_color=color.white, bgcolor=color.new(color.green, 60))
    table.cell(dbgTable, 1, 0, bullDbgText, text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dbgTable, 0, 1, "Bear", text_color=color.white, bgcolor=color.new(color.red, 60))
    table.cell(dbgTable, 1, 1, bearDbgText, text_color=color.white, bgcolor=color.new(color.black, 15))

alertcondition(bullTrigger, title="Bullish Trend Overextended", message="Uptrend confirmed and RSI is overbought -- watch for reversal")
alertcondition(bearTrigger, title="Bearish Trend Underextended", message="Downtrend confirmed and RSI is oversold -- watch for reversal")
alertcondition(bullBreak, title="Bullish Trend Line Broken", message="Price closed below the overextended uptrend line")
alertcondition(bearBreak, title="Bearish Trend Line Broken", message="Price closed above the underextended downtrend line")
