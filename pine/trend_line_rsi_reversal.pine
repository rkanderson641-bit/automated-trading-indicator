//@version=6
indicator("Trend Line RSI Reversal", overlay=true, max_lines_count=500, max_labels_count=500)

// ---------------------------------------------------------------------------
// Inputs
// ---------------------------------------------------------------------------
swingBars       = input.int(8, "Swing Lookback/Lookahead Bars", minval=1, group="Trend Structure")
atrLen          = input.int(14, "ATR Length", minval=1, group="Trend Structure")
minBreakAtrMult = input.float(1.0, "Minimum break size (x ATR)", minval=0.1, step=0.1, group="Trend Structure")
rsiLen          = input.int(14, "RSI Length", minval=1, group="RSI")
rsiMaLen        = input.int(9, "RSI MA Length", minval=1, group="RSI")
overbought      = input.float(70, "Overbought (overextended)", group="RSI")
oversold        = input.float(30, "Oversold (underextended)", group="RSI")
bullColor       = input.color(color.green, "Bullish Trend Line Color", group="Style")
bearColor       = input.color(color.red, "Bearish Trend Line Color", group="Style")
showLabels      = input.bool(true, "Show signal/break labels", group="Style")
showDebug       = input.bool(true, "Show debug markers (structure break)", group="Debug")

// ---------------------------------------------------------------------------
// Trend lines connect every confirmed swing low (uptrend) / swing high
// (downtrend) along the move, drawn as a series of connected line.new
// segments rather than a single 2-point line. Once a line is drawn it
// stays on the chart through the end of the session -- it is never
// deleted, even after an opposite structure break -- so the full history
// of overextended/underextended trend lines remains visible for the day.
//
// Debugging history: a 2-point line connecting only the most recent pair
// of pivots technically rendered but was a short, easily-missed segment.
// Switching to a growing chain failed silently at first because the chain
// was seeded using only the pivot value confirmed on the EXACT breakout
// bar -- pivots only confirm every swingBars*2 bars, so on most breakout
// bars there is no fresh pivot, leaving just 1 point (failing a 2-point
// minimum with no visible symptom other than "no line"). The fix is to
// track the most recently confirmed swing high/low continuously,
// independent of trend state, so a real anchor point is always available
// to pair with the breakout bar when seeding a new chain.
// ---------------------------------------------------------------------------
pivotHighVal = ta.pivothigh(high, swingBars, swingBars)
pivotLowVal  = ta.pivotlow(low, swingBars, swingBars)
pivotBarIdx  = bar_index - swingBars

var float lastSwingHigh    = na
var int   lastSwingHighBar = na
var float lastSwingLow     = na
var int   lastSwingLowBar  = na

if not na(pivotHighVal)
    lastSwingHigh    := pivotHighVal
    lastSwingHighBar := pivotBarIdx

if not na(pivotLowVal)
    lastSwingLow    := pivotLowVal
    lastSwingLowBar := pivotBarIdx

// Structure break: price closes beyond the most recent prior swing
// high/low BY AT LEAST minBreakAtrMult x ATR. Stays "armed" until the
// opposite break occurs. Without the ATR margin, any close even a tick
// beyond a recent pivot counted as a "break" -- in a choppy multi-day
// range with many qualifying pivots, that produced a break almost every
// 2-4 bars in alternating directions.
// ---------------------------------------------------------------------------
atrVal = ta.atr(atrLen)

var float breakLastHigh   = na
var float breakLastLow    = na
var bool  hadBullishBreak = false
var bool  hadBearishBreak = false

if not na(pivotHighVal)
    breakLastHigh := pivotHighVal

if not na(pivotLowVal)
    breakLastLow := pivotLowVal

bullishBreakNowRaw = not na(breakLastHigh) and close > breakLastHigh + atrVal * minBreakAtrMult
bearishBreakNowRaw = not na(breakLastLow) and close < breakLastLow - atrVal * minBreakAtrMult

// On a rare bar where price simultaneously clears both thresholds (a wide
// bar straddling both break levels), only let ONE side fire -- letting
// both bullish/bearish blocks run on the same bar made them fight over
// the shared hadBullishBreak/hadBearishBreak flags, leaving them
// momentarily out of sync with which chain was actually still being
// tracked. Bullish takes priority arbitrarily; this case is rare enough
// that the choice of which side wins doesn't meaningfully matter.
bullishBreakNow = bullishBreakNowRaw
bearishBreakNow = bearishBreakNowRaw and not bullishBreakNowRaw

var array<int>   bullChainBars   = array.new<int>()
var array<float> bullChainPrices = array.new<float>()
var array<int>   bearChainBars   = array.new<int>()
var array<float> bearChainPrices = array.new<float>()

var array<line> bullSegments        = array.new<line>()
var array<line> bearSegments        = array.new<line>()
var int         bullSegmentsDrawnFor = 0
var int         bearSegmentsDrawnFor = 0

var bool trackingBull = false
var bool trackingBear = false

bullBreak = false
bearBreak = false
bullChainChanged = false
bearChainChanged = false

if bullishBreakNow
    freshBullStart = not hadBullishBreak
    breakLastHigh   := close
    hadBullishBreak := true
    hadBearishBreak := false
    if showDebug
        label.new(bar_index, high, text="BREAK", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
    if freshBullStart
        array.clear(bullChainBars)
        array.clear(bullChainPrices)
        bullSegmentsDrawnFor := 0
        if not na(lastSwingLowBar)
            array.push(bullChainBars, lastSwingLowBar)
            array.push(bullChainPrices, lastSwingLow)
        array.push(bullChainBars, bar_index)
        array.push(bullChainPrices, close)
        bullChainChanged := true
    // A fresh bullish break means the downtrend it was tracking no
    // longer holds. The bearish line itself is left in place -- it stays
    // on the chart for the rest of the session rather than being deleted.
    if trackingBear
        bearBreak := true
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_up, color=color.new(color.green, 50), textcolor=color.white, size=size.small)
        trackingBear := false

if bearishBreakNow
    freshBearStart = not hadBearishBreak
    breakLastLow    := close
    hadBearishBreak := true
    hadBullishBreak := false
    if showDebug
        label.new(bar_index, low, text="BREAK", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
    if freshBearStart
        array.clear(bearChainBars)
        array.clear(bearChainPrices)
        bearSegmentsDrawnFor := 0
        if not na(lastSwingHighBar)
            array.push(bearChainBars, lastSwingHighBar)
            array.push(bearChainPrices, lastSwingHigh)
        array.push(bearChainBars, bar_index)
        array.push(bearChainPrices, close)
        bearChainChanged := true
    // A fresh bearish break means the uptrend it was tracking no longer
    // holds. The bullish line itself is left in place -- see the matching
    // comment in the bullish branch above.
    if trackingBull
        bullBreak := true
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_down, color=color.new(color.red, 50), textcolor=color.white, size=size.small)
        trackingBull := false

// Collect additional swing points into the active chain as the trend
// continues, skipping any that don't extend the structure (a lower low
// during an uptrend's chain, or a higher high during a downtrend's chain).
if hadBullishBreak and not na(pivotLowVal)
    if array.size(bullChainPrices) == 0 or pivotLowVal > array.get(bullChainPrices, array.size(bullChainPrices) - 1)
        array.push(bullChainBars, pivotBarIdx)
        array.push(bullChainPrices, pivotLowVal)
        bullChainChanged := true
        if showDebug
            label.new(pivotBarIdx, pivotLowVal, text="+", style=label.style_circle, color=color.new(bullColor, 30), size=size.tiny)

if hadBearishBreak and not na(pivotHighVal)
    if array.size(bearChainPrices) == 0 or pivotHighVal < array.get(bearChainPrices, array.size(bearChainPrices) - 1)
        array.push(bearChainBars, pivotBarIdx)
        array.push(bearChainPrices, pivotHighVal)
        bearChainChanged := true
        if showDebug
            label.new(pivotBarIdx, pivotHighVal, text="+", style=label.style_circle, color=color.new(bearColor, 30), size=size.tiny)

rsiVal = ta.rsi(close, rsiLen)
rsiMa  = ta.sma(rsiVal, rsiMaLen)

// "Armed" latches prevent re-firing every bar while RSI stays past the
// threshold, and reset once RSI comes back inside the bands.
var bool bullArmed = false
var bool bearArmed = false

if rsiMa <= overbought
    bullArmed := false
if rsiMa >= oversold
    bearArmed := false

bullTrigger = hadBullishBreak and rsiMa > overbought and not bullArmed
bearTrigger = hadBearishBreak and rsiMa < oversold and not bearArmed

if bullTrigger
    bullArmed    := true
    trackingBull := true
    if showLabels
        label.new(bar_index, low, text="OVEREXTENDED", style=label.style_label_up, color=color.new(bullColor, 70), textcolor=color.white, size=size.small)

if bearTrigger
    bearArmed    := true
    trackingBear := true
    if showLabels
        label.new(bar_index, high, text="UNDEREXTENDED", style=label.style_label_down, color=color.new(bearColor, 70), textcolor=color.white, size=size.small)

// (Re)draw the chain as connected line.new segments whenever it's
// actively being tracked and either just started or just grew a new
// point. Past segments are left in place (never deleted) so the line
// stays on the chart for the rest of the session even after the move
// ends and a new chain starts forming -- only the most recent unbroken
// run of segments gets extended/redrawn as the chain grows; segments
// drawn for an already-completed leg are permanent history.
// Both arrays in a chain pair (bars/prices) are always pushed to together,
// but bullSegmentsDrawnFor is a separately-tracked var that can end up
// stale relative to the chain's current size in edge cases (e.g. a bar
// where price simultaneously satisfies both the bullish and bearish break
// thresholds, briefly flipping hadBullishBreak/hadBearishBreak twice in
// one bar). Clamping the loop bound to the smaller of the two array
// sizes, and clamping the start index down to a valid range, guarantees
// array.get() is never called with an out-of-bounds index regardless of
// how that staleness arises.
bullChainLen = math.min(array.size(bullChainBars), array.size(bullChainPrices))
bearChainLen = math.min(array.size(bearChainBars), array.size(bearChainPrices))

if trackingBull and (bullTrigger or bullChainChanged) and bullChainLen >= 2
    bullStart = math.min(bullSegmentsDrawnFor, bullChainLen - 2)
    bullStart := math.max(bullStart, 0)
    for i = bullStart to bullChainLen - 2
        seg = line.new(array.get(bullChainBars, i), array.get(bullChainPrices, i), array.get(bullChainBars, i + 1), array.get(bullChainPrices, i + 1), extend=extend.none, color=bullColor, width=2)
        array.push(bullSegments, seg)
    bullSegmentsDrawnFor := bullChainLen - 1

if trackingBear and (bearTrigger or bearChainChanged) and bearChainLen >= 2
    bearStart = math.min(bearSegmentsDrawnFor, bearChainLen - 2)
    bearStart := math.max(bearStart, 0)
    for i = bearStart to bearChainLen - 2
        seg = line.new(array.get(bearChainBars, i), array.get(bearChainPrices, i), array.get(bearChainBars, i + 1), array.get(bearChainPrices, i + 1), extend=extend.none, color=bearColor, width=2)
        array.push(bearSegments, seg)
    bearSegmentsDrawnFor := bearChainLen - 1

alertcondition(bullTrigger, title="Bullish Trend Overextended", message="Uptrend confirmed and RSI is overbought -- watch for reversal")
alertcondition(bearTrigger, title="Bearish Trend Underextended", message="Downtrend confirmed and RSI is oversold -- watch for reversal")
alertcondition(bullBreak, title="Bullish Trend Line Broken", message="Price closed below the overextended uptrend line")
alertcondition(bearBreak, title="Bearish Trend Line Broken", message="Price closed above the underextended downtrend line")
