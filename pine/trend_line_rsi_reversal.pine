//@version=6
indicator("Trend Line RSI Reversal", overlay=true, max_lines_count=500, max_labels_count=500)

// ---------------------------------------------------------------------------
// Inputs
// ---------------------------------------------------------------------------
swingBars       = input.int(8, "Swing Lookback/Lookahead Bars", minval=1, group="Trend Structure")
atrLen          = input.int(14, "ATR Length", minval=1, group="Trend Structure")
minBreakAtrMult = input.float(1.0, "Minimum break size (x ATR)", minval=0.1, step=0.1, group="Trend Structure")
rsiLen          = input.int(14, "RSI Length", minval=1, group="RSI")
rsiMaLen        = input.int(9, "RSI MA Length", minval=1, group="RSI")
overbought      = input.float(70, "Overbought (overextended)", group="RSI")
oversold        = input.float(30, "Oversold (underextended)", group="RSI")
bullColor       = input.color(color.green, "Bullish Trend Line Color", group="Style")
bearColor       = input.color(color.red, "Bearish Trend Line Color", group="Style")
showLabels      = input.bool(true, "Show signal/break labels", group="Style")
extendBars      = input.int(8, "Extend each line past its last point (bars)", minval=0, group="Style")
showDebug       = input.bool(true, "Show debug markers (structure break)", group="Debug")

// ---------------------------------------------------------------------------
// A trend line has a fixed origin -- the swing low (uptrend) or swing high
// (downtrend) that launched the move, captured once when the leg starts --
// and a far point that continuously tracks the running extreme (the
// highest high so far for an uptrend, the lowest low so far for a
// downtrend) using each bar's own real wick. It updates every single bar
// a new extreme prints, with no pivot-confirmation lag, so it never falls
// behind price the way a pivot-gated chain did. If price stops making new
// extremes, the line simply stays put at the last one until either price
// resumes extending it or a genuine opposite structure break ends the leg
// (at which point the line freezes permanently, left on the chart).
// ---------------------------------------------------------------------------
pivotHighVal = ta.pivothigh(high, swingBars, swingBars)
pivotLowVal  = ta.pivotlow(low, swingBars, swingBars)
pivotBarIdx  = bar_index - swingBars

var float lastPivotHigh    = na
var int   lastPivotHighBar = na
var float lastPivotLow     = na
var int   lastPivotLowBar  = na

if not na(pivotHighVal)
    lastPivotHigh    := pivotHighVal
    lastPivotHighBar := pivotBarIdx

if not na(pivotLowVal)
    lastPivotLow    := pivotLowVal
    lastPivotLowBar := pivotBarIdx

atrVal = ta.atr(atrLen)

var float breakLastHigh   = na
var float breakLastLow    = na
var bool  hadBullishBreak = false
var bool  hadBearishBreak = false

// breakLastHigh/breakLastLow always ratchet to the most recent confirmed
// pivot, regardless of current trend state. An earlier attempt froze the
// OPPOSITE-direction level once a trend was confirmed, on the theory that
// a reversal-direction line appearing mid-trend was a bug -- but a close
// back above the most recent lower-high pivot (or below the most recent
// higher-low) IS a legitimate micro-reversal/bounce, which is exactly
// what this indicator is meant to catch, even within a larger trend.
// Freezing the level meant a reversal had to clear the price level from
// before the ENTIRE prior trend even started -- an almost unreachable
// bar after any real move -- so breaks (and therefore lines) almost
// stopped firing at all.
if not na(pivotHighVal)
    breakLastHigh := pivotHighVal
if not na(pivotLowVal)
    breakLastLow := pivotLowVal

bullishBreakNowRaw = not na(breakLastHigh) and close > breakLastHigh + atrVal * minBreakAtrMult
bearishBreakNowRaw = not na(breakLastLow) and close < breakLastLow - atrVal * minBreakAtrMult

// On a rare bar where price simultaneously clears both thresholds, only
// let ONE side fire so the two break blocks can't fight over the shared
// hadBullishBreak/hadBearishBreak flags.
bullishBreakNow = bullishBreakNowRaw
bearishBreakNow = bearishBreakNowRaw and not bullishBreakNowRaw

var line bullLine    = na
var line bearLine    = na
var line bullCapLine = na
var line bearCapLine = na
var bool trackingBull = false
var bool trackingBear = false

var int   bullOriginBar   = na
var float bullOriginPrice = na
var int   bullFarBar      = na
var float bullFarPrice    = na

var int   bearOriginBar   = na
var float bearOriginPrice = na
var int   bearFarBar      = na
var float bearFarPrice    = na

bullBreak = false
bearBreak = false

if bullishBreakNow
    freshBullStart  = not hadBullishBreak
    breakLastHigh   := close
    hadBullishBreak := true
    hadBearishBreak := false
    if showDebug
        label.new(bar_index, high, text="BREAK", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
    if freshBullStart
        bullOriginBar   := lastPivotLowBar
        bullOriginPrice := lastPivotLow
        bullFarBar      := bullOriginBar
        bullFarPrice    := bullOriginPrice
        // Forget (don't delete) the previous leg's line/cap -- they stay
        // on the chart as permanent history of that completed leg.
        bullLine    := na
        bullCapLine := na
    // A fresh bullish break means the downtrend it was tracking no
    // longer holds. The bearish line itself is left in place on the chart.
    if trackingBear
        bearBreak := true
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_up, color=color.new(color.green, 50), textcolor=color.white, size=size.small)
        trackingBear := false

if bearishBreakNow
    freshBearStart  = not hadBearishBreak
    breakLastLow    := close
    hadBearishBreak := true
    hadBullishBreak := false
    if showDebug
        label.new(bar_index, low, text="BREAK", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
    if freshBearStart
        bearOriginBar   := lastPivotHighBar
        bearOriginPrice := lastPivotHigh
        bearFarBar      := bearOriginBar
        bearFarPrice    := bearOriginPrice
        bearLine    := na
        bearCapLine := na
    // A fresh bearish break means the uptrend it was tracking no longer
    // holds. The bullish line itself is left in place on the chart.
    if trackingBull
        bullBreak := true
        if showLabels
            label.new(bar_index, close, text="TREND BREAK", style=label.style_label_down, color=color.new(color.red, 50), textcolor=color.white, size=size.small)
        trackingBull := false

// Continuously track the running extreme since the leg started -- a real
// wick value updated every bar, never waiting on pivot confirmation.
if hadBullishBreak and not na(bullOriginBar) and high > bullFarPrice
    bullFarBar   := bar_index
    bullFarPrice := high

if hadBearishBreak and not na(bearOriginBar) and low < bearFarPrice
    bearFarBar   := bar_index
    bearFarPrice := low

rsiVal = ta.rsi(close, rsiLen)
rsiMa  = ta.sma(rsiVal, rsiMaLen)

// "Armed" latches prevent re-firing every bar while RSI stays past the
// threshold, and reset once RSI comes back inside the bands.
var bool bullArmed = false
var bool bearArmed = false

if rsiMa <= overbought
    bullArmed := false
if rsiMa >= oversold
    bearArmed := false

bullTrigger = hadBullishBreak and rsiMa > overbought and not bullArmed
bearTrigger = hadBearishBreak and rsiMa < oversold and not bearArmed

if bullTrigger
    bullArmed    := true
    trackingBull := true
    if showLabels
        label.new(bar_index, low, text="OVEREXTENDED", style=label.style_label_up, color=color.new(bullColor, 70), textcolor=color.white, size=size.small)

if bearTrigger
    bearArmed    := true
    trackingBear := true
    if showLabels
        label.new(bar_index, high, text="UNDEREXTENDED", style=label.style_label_down, color=color.new(bearColor, 70), textcolor=color.white, size=size.small)

// Draw/update the line for as long as it's being tracked -- the origin
// never moves; the far point continuously follows the running extreme
// computed above. extendBars adds a small overshoot past the far point,
// projected along the line's own slope, so it doesn't stop dead exactly
// at the last touch.
if trackingBull and not na(bullOriginBar)
    if na(bullLine)
        bullLine := line.new(bullOriginBar, bullOriginPrice, bullFarBar, bullFarPrice, extend=extend.none, color=bullColor, width=2)
    else
        line.set_xy2(bullLine, bullFarBar, bullFarPrice)
    // Only when the far point has actually moved past the origin -- right
    // when a leg starts, before any new high has printed, they're still
    // the same point and a slope is undefined (division by zero).
    if extendBars > 0 and bullFarBar != bullOriginBar
        if not na(bullCapLine)
            line.delete(bullCapLine)
        bullSlope = (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar)
        bullCapLine := line.new(bullFarBar, bullFarPrice, bullFarBar + extendBars, bullFarPrice + bullSlope * extendBars, extend=extend.none, color=bullColor, width=2)

if trackingBear and not na(bearOriginBar)
    if na(bearLine)
        bearLine := line.new(bearOriginBar, bearOriginPrice, bearFarBar, bearFarPrice, extend=extend.none, color=bearColor, width=2)
    else
        line.set_xy2(bearLine, bearFarBar, bearFarPrice)
    if extendBars > 0 and bearFarBar != bearOriginBar
        if not na(bearCapLine)
            line.delete(bearCapLine)
        bearSlope = (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar)
        bearCapLine := line.new(bearFarBar, bearFarPrice, bearFarBar + extendBars, bearFarPrice + bearSlope * extendBars, extend=extend.none, color=bearColor, width=2)

alertcondition(bullTrigger, title="Bullish Trend Overextended", message="Uptrend confirmed and RSI is overbought -- watch for reversal")
alertcondition(bearTrigger, title="Bearish Trend Underextended", message="Downtrend confirmed and RSI is oversold -- watch for reversal")
alertcondition(bullBreak, title="Bullish Trend Line Broken", message="Price closed below the overextended uptrend line")
alertcondition(bearBreak, title="Bearish Trend Line Broken", message="Price closed above the underextended downtrend line")
