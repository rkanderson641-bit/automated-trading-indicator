//@version=6
indicator("Trend Line Strategy", overlay=true, max_lines_count=500, max_labels_count=500)

// ---------------------------------------------------------------------------
// Inputs
// ---------------------------------------------------------------------------
swingBars        = input.int(8, "Swing Lookback/Lookahead Bars (trend direction)", minval=1, group="Trend Structure")
touchBars        = input.int(3, "Touch Point Lookback/Lookahead Bars (line anchors)", minval=1, group="Trend Structure")
atrLen           = input.int(14, "ATR Length", minval=1, group="Trend Structure")
minBreakAtrMult  = input.float(1.0, "Minimum break size (x ATR)", minval=0.1, step=0.1, group="Trend Structure")
divergeAtrMult   = input.float(0.5, "Divergence sensitivity margin (x ATR)", minval=0.0, step=0.1, group="Trend Structure")
backtestBars     = input.int(30, "Backtest window after a break (bars)", minval=1, group="Confirmation")
backtestAtrMult  = input.float(0.3, "Backtest proximity (x ATR)", minval=0.0, step=0.1, group="Confirmation")
bullColor        = input.color(color.green, "Bullish Trend Line Color", group="Style")
bearColor        = input.color(color.red, "Bearish Trend Line Color", group="Style")
bullDivergeColor = input.color(#80FF80, "Bullish Divergent Line Color", group="Style")
bearDivergeColor = input.color(#FF8080, "Bearish Divergent Line Color", group="Style")
showLabels       = input.bool(true, "Show signal/break/confirmation labels", group="Style")
showReactions    = input.bool(true, "Show reaction (wick-bounce) markers", group="Style")
freezeExtendBars = input.int(6, "Extend a frozen line past its break point (bars)", minval=0, group="Style")
showDebug        = input.bool(true, "Show debug markers (touch points)", group="Debug")

// ---------------------------------------------------------------------------
// Rebuilt from a trend-line tutorial (The Peachy Investor, gold futures on
// ThinkOrSwim): an uptrend line connects 2+ ascending swing lows, a
// downtrend line connects 2+ descending swing highs -- same-type pivots
// only, never a high to a low. There is NO RSI gate of any kind here: a
// line is drawn the instant it has two real touch points and stays visible
// the whole time it's structurally valid, exactly like a hand-drawn trend
// line -- not just during some oscillator extreme.
//
// Two separate pivot lookbacks, same as before: `swingBars` (wider) picks
// the origin pivot and overall trend direction; `touchBars` (narrower)
// finds the touch points that roll a line's far point forward, since a
// single wide lookback is too strict to catch every real touch during a
// fast or choppy move.
//
// Branching: when a new touch point continues the structure but lands
// meaningfully beyond where the existing line already projects (steeper
// than expected), the existing line freezes in place and a new, steeper
// line begins from that same point, drawn in a lighter color. A branch is
// only accepted if it wouldn't cut through any candle's body in between
// (wick-only, never a body) and if its two points are at least touchBars
// apart -- enough to rule out two points bracketing one single freak
// candle, without blocking a real steep, fast, multi-bar move just
// because its touch points land closer together than a slower trend's
// would. A sustained steep move is exactly when this should fire most
// often, not be blocked.
//
// A line only ever touches WICKS, never closes through a candle body --
// this is checked, not assumed.
//
// Regime state: exactly one of {none yet, bullish leg active, bearish leg
// active} at any time, and it only ever changes in two places: the very
// first decisive break at startup, or an actual break of whatever is
// currently active in that direction (a pending single touch point with
// no line yet, or a real 2+ point line). It does NOT change in response
// to a generic "price broke some recent pivot" check recomputed fresh
// every bar -- that was tried and was too twitchy. A confirmed pivot
// ratchets to the MOST RECENT pivot of that type regardless of whether
// it's higher or lower than the previous one, so during a choppy decline
// a tiny countertrend bounce could exceed a recently-lowered pivot and
// falsely flip the regime, wiping out a perfectly good in-progress line
// and restarting from scratch. That produced two symptoms from one bug: a
// fan of short branches all sharing one stale origin (every false flip
// re-grabbing the same old swing point) and long blank stretches (a line
// repeatedly killed before it ever earned a second touch point).
//
// Reactions vs. real breaks: a wick can cross a line while the candle's
// close stays on the correct side -- that's a reaction (the line held),
// not a break. A real break only happens when CLOSE moves through the
// line (or, for a not-yet-confirmed origin, through that origin price) by
// more than the ATR margin.
//
// Confirmation via backtest: when a line genuinely breaks, that's a
// potential reversal, but it can fake out. So instead of signaling
// immediately, the broken level is watched for `backtestBars` bars: if
// price comes back to test it (within `backtestAtrMult` x ATR) and then
// closes back away in the new direction, that's a confirmed entry. If
// price instead closes back through to the original side first, the break
// is tagged a fakeout and the watch is cancelled.
//
// Bar-index drawing limit: a leg's origin can legitimately stay alive for
// thousands of bars (a real, long-running, never-broken trend, or a leg
// frozen on an intrusion waiting for the next clean touch point). Once
// that gap from the current bar passes ~10000, Pine refuses to anchor a
// line/label there by bar index ("x1 too far from current bar"). Every
// origin/far point therefore also carries the TIMESTAMP it was set at
// (captured with a small, always-safe lookback like time[touchBars] at
// the moment it's first recorded, never reconstructed later for an
// arbitrarily old bar), and lines/labels anchored to those points draw
// with xloc.bar_time instead of a bar index, which has no such limit.
// ---------------------------------------------------------------------------

// Returns true if the straight line from (fromBar, fromPrice) to (toBar,
// toPrice) would cut into the open/close body of any bar strictly between
// the two -- touching a wick is fine, this only flags an actual body cut.
lineEntersBody(int fromBar, float fromPrice, int toBar, float toPrice) =>
    slope = toBar != fromBar ? (toPrice - fromPrice) / (toBar - fromBar) : 0.0
    entersBody = false
    // Pine's [] history-referencing operator only accepts an offset up to
    // 10000 bars back. An origin that's gone very stale (a leg frozen or
    // still pending its second touch point for thousands of bars while
    // bar_index keeps climbing) can make this span exceed that and crash.
    // Clamp the scan to the most recent maxLookback bars of the span
    // instead of however far back fromBar actually is -- the older portion
    // was already verified clean incrementally, bar by bar, as the line
    // was first drawn (see the continuous per-bar check further down), so
    // re-scanning all the way back to a stale origin isn't needed.
    maxLookback = 9000
    earliestBar = math.max(fromBar + 1, bar_index - maxLookback)
    latestBar   = toBar - 1
    if latestBar >= earliestBar
        for i = earliestBar to latestBar
            offset = bar_index - i
            lineVal = fromPrice + slope * (i - fromBar)
            bodyTop = math.max(open[offset], close[offset])
            bodyBottom = math.min(open[offset], close[offset])
            if lineVal < bodyTop and lineVal > bodyBottom
                entersBody := true
    entersBody

pivotHighVal = ta.pivothigh(high, swingBars, swingBars)
pivotLowVal  = ta.pivotlow(low, swingBars, swingBars)
pivotBarIdx  = bar_index - swingBars
pivotBarTime = time[swingBars]

touchPivotHighVal = ta.pivothigh(high, touchBars, touchBars)
touchPivotLowVal  = ta.pivotlow(low, touchBars, touchBars)
touchPivotBarIdx  = bar_index - touchBars
touchPivotBarTime = time[touchBars]

// lastPivotHigh/lastPivotLow ratchet to the MOST RECENT confirmed swing
// pivot, regardless of current trend state or whether it's higher/lower
// than the previous one -- used only to seed a new origin the moment a
// regime change happens, never to trigger that change itself. The *Time
// companions are captured the same bar the pivot confirms, at a small,
// always-safe swingBars lookback -- never reconstructed later for a bar
// that's since gone far in the past (see the "Bar-index drawing limit"
// note above).
var float lastPivotHigh     = na
var int   lastPivotHighBar  = na
var int   lastPivotHighTime = na
var float lastPivotLow      = na
var int   lastPivotLowBar   = na
var int   lastPivotLowTime  = na

if not na(pivotHighVal)
    lastPivotHigh     := pivotHighVal
    lastPivotHighBar  := pivotBarIdx
    lastPivotHighTime := pivotBarTime

if not na(pivotLowVal)
    lastPivotLow     := pivotLowVal
    lastPivotLowBar  := pivotBarIdx
    lastPivotLowTime := pivotBarTime

atrVal = ta.atr(atrLen)

// trendState: 0 = no direction established yet, 1 = bullish leg active,
// -1 = bearish leg active. See the "Regime state" comment above for why
// this only ever changes at startup or at an actual break of whatever is
// currently active -- never from lastPivotHigh/lastPivotLow directly.
var int trendState = 0

var line bullLine = na
var line bearLine = na
var bool trackingBull = false
var bool trackingBear = false
var bool bullIsDivergent = false
var bool bearIsDivergent = false

var int   bullOriginBar   = na
var int   bullOriginTime  = na
var float bullOriginPrice = na
var int   bullFarBar      = na
var int   bullFarTime     = na
var float bullFarPrice    = na

var int   bearOriginBar   = na
var int   bearOriginTime  = na
var float bearOriginPrice = na
var int   bearFarBar      = na
var int   bearFarTime     = na
var float bearFarPrice    = na

// Pending backtest-confirmation watches, one slot per direction -- a new
// break of the same direction simply replaces whatever watch was pending.
var bool  pendingLongActive  = false
var float pendingLongLevel   = na
var int   pendingLongBar     = na
var bool  pendingLongTested  = false

var bool  pendingShortActive = false
var float pendingShortLevel  = na
var int   pendingShortBar    = na
var bool  pendingShortTested = false

bullBreak     = false
bearBreak     = false
confirmedLong  = false
confirmedShort = false

// Startup only: pick the very first direction off a decisive break of the
// most recent confirmed pivot. Once trendState is non-zero, this never
// runs again -- all later direction changes come from the break checks
// further down, against whatever is actually being tracked.
if trendState == 0
    bootstrapBullBreak = not na(lastPivotHigh) and close > lastPivotHigh + atrVal * minBreakAtrMult
    bootstrapBearBreak = not na(lastPivotLow) and close < lastPivotLow - atrVal * minBreakAtrMult
    if bootstrapBullBreak and not bootstrapBearBreak
        trendState      := 1
        bullOriginBar   := lastPivotLowBar
        bullOriginTime  := lastPivotLowTime
        bullOriginPrice := lastPivotLow
        bullFarBar      := bullOriginBar
        bullFarTime     := bullOriginTime
        bullFarPrice    := bullOriginPrice
        bullIsDivergent := false
        trackingBull    := false
        bullLine        := na
        if showDebug
            label.new(bar_index, high, text="BREAK", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
            if not na(bullOriginTime)
                label.new(bullOriginTime, bullOriginPrice, text="L", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if bootstrapBearBreak and not bootstrapBullBreak
        trendState      := -1
        bearOriginBar   := lastPivotHighBar
        bearOriginTime  := lastPivotHighTime
        bearOriginPrice := lastPivotHigh
        bearFarBar      := bearOriginBar
        bearFarTime     := bearOriginTime
        bearFarPrice    := bearOriginPrice
        bearIsDivergent := false
        trackingBear    := false
        bearLine        := na
        if showDebug
            label.new(bar_index, low, text="BREAK", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
            if not na(bearOriginTime)
                label.new(bearOriginTime, bearOriginPrice, text="H", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)

// Roll the far point forward on each new SAME-TYPE touch point that
// continues the structure (a lower high while bearish, a higher low while
// bullish). A touch point that fails to continue is simply ignored -- not
// a touch point, the anchor stays exactly as it was. The moment the far
// point first becomes a real second point (different from the origin), a
// trend line exists by definition and starts being drawn -- no RSI or any
// other gate involved.
//
// A touch point that DOES continue only ever gets accepted if the
// resulting line stays wick-only the ENTIRE way from origin to this new
// point -- not just the newest segment. If extending the existing line
// that far would cut into some earlier candle's body, but anchoring a
// fresh, shorter line from just the last touch point to this new one
// would stay clean, that shorter line is used instead (the same
// lighter "divergent" styling as a steepening branch, just triggered by
// cleanliness instead of slope). If neither the full line nor the short
// one would stay clean, the touch point is ignored rather than drawn
// through a body.
if trendState == 1 and not na(touchPivotLowVal)
    if na(bullOriginBar)
        bullOriginBar   := touchPivotBarIdx
        bullOriginTime  := touchPivotBarTime
        bullOriginPrice := touchPivotLowVal
        bullFarBar      := bullOriginBar
        bullFarTime     := bullOriginTime
        bullFarPrice    := bullOriginPrice
        bullIsDivergent := false
        if showDebug
            label.new(bullOriginTime, bullOriginPrice, text="L", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if touchPivotLowVal > bullFarPrice
        bullEstSlope      = bullFarBar != bullOriginBar ? (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar) : 0.0
        bullProjected     = bullFarPrice + bullEstSlope * (touchPivotBarIdx - bullFarBar)
        bullDivergesSteep = bullFarBar != bullOriginBar and touchPivotLowVal > bullProjected + atrVal * divergeAtrMult
        bullEnoughRun     = touchPivotBarIdx - bullFarBar >= touchBars
        bullShortClean    = not lineEntersBody(bullFarBar, bullFarPrice, touchPivotBarIdx, touchPivotLowVal)
        bullFullClean     = not lineEntersBody(bullOriginBar, bullOriginPrice, touchPivotBarIdx, touchPivotLowVal)
        if bullEnoughRun and bullShortClean and (bullDivergesSteep or not bullFullClean)
            bullLine        := na
            bullIsDivergent := true
            bullOriginBar   := bullFarBar
            bullOriginTime  := bullFarTime
            bullOriginPrice := bullFarPrice
            bullFarBar      := touchPivotBarIdx
            bullFarTime     := touchPivotBarTime
            bullFarPrice    := touchPivotLowVal
            trackingBull    := true
            if showDebug
                label.new(bullFarTime, bullFarPrice, text="D", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
        else if bullFullClean
            bullFarBar   := touchPivotBarIdx
            bullFarTime  := touchPivotBarTime
            bullFarPrice := touchPivotLowVal
            trackingBull := true
            if showDebug
                label.new(bullFarTime, bullFarPrice, text="+", xloc=xloc.bar_time, style=label.style_circle, color=color.new(bullColor, 30), size=size.tiny)
        else
            if showDebug
                label.new(touchPivotBarIdx, touchPivotLowVal, text="x", style=label.style_circle, color=color.new(color.gray, 60), size=size.tiny)
    else
        if showDebug
            label.new(touchPivotBarIdx, touchPivotLowVal, text="x", style=label.style_circle, color=color.new(color.gray, 60), size=size.tiny)

if trendState == -1 and not na(touchPivotHighVal)
    if na(bearOriginBar)
        bearOriginBar   := touchPivotBarIdx
        bearOriginTime  := touchPivotBarTime
        bearOriginPrice := touchPivotHighVal
        bearFarBar      := bearOriginBar
        bearFarTime     := bearOriginTime
        bearFarPrice    := bearOriginPrice
        bearIsDivergent := false
        if showDebug
            label.new(bearOriginTime, bearOriginPrice, text="H", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if touchPivotHighVal < bearFarPrice
        bearEstSlope      = bearFarBar != bearOriginBar ? (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar) : 0.0
        bearProjected     = bearFarPrice + bearEstSlope * (touchPivotBarIdx - bearFarBar)
        bearDivergesSteep = bearFarBar != bearOriginBar and touchPivotHighVal < bearProjected - atrVal * divergeAtrMult
        bearEnoughRun     = touchPivotBarIdx - bearFarBar >= touchBars
        bearShortClean    = not lineEntersBody(bearFarBar, bearFarPrice, touchPivotBarIdx, touchPivotHighVal)
        bearFullClean     = not lineEntersBody(bearOriginBar, bearOriginPrice, touchPivotBarIdx, touchPivotHighVal)
        if bearEnoughRun and bearShortClean and (bearDivergesSteep or not bearFullClean)
            bearLine        := na
            bearIsDivergent := true
            bearOriginBar   := bearFarBar
            bearOriginTime  := bearFarTime
            bearOriginPrice := bearFarPrice
            bearFarBar      := touchPivotBarIdx
            bearFarTime     := touchPivotBarTime
            bearFarPrice    := touchPivotHighVal
            trackingBear    := true
            if showDebug
                label.new(bearFarTime, bearFarPrice, text="D", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
        else if bearFullClean
            bearFarBar   := touchPivotBarIdx
            bearFarTime  := touchPivotBarTime
            bearFarPrice := touchPivotHighVal
            trackingBear := true
            if showDebug
                label.new(bearFarTime, bearFarPrice, text="+", xloc=xloc.bar_time, style=label.style_circle, color=color.new(bearColor, 30), size=size.tiny)
        else
            if showDebug
                label.new(touchPivotBarIdx, touchPivotHighVal, text="x", style=label.style_circle, color=color.new(color.gray, 60), size=size.tiny)
    else
        if showDebug
            label.new(touchPivotBarIdx, touchPivotHighVal, text="x", style=label.style_circle, color=color.new(color.gray, 60), size=size.tiny)

// Once a line is being tracked, extend it to the current bar along its
// established slope every single bar -- exactly like auto_support_
// resistance.pine's level lines -- instead of sitting frozen at its last
// confirmed touch point. But that projection has to be checked against
// TODAY's body too, every single bar, not just at the moment a touch point
// updates -- price drifting away from an old anchor over many quiet bars
// (no new touch point at all) can walk the projected line into a body just
// as easily as a bad touch-point update can. A Pine line is always one
// continuous straight segment, though, so there's no such thing as
// "skipping" the one bar that would intrude while still drawing the bars
// after it -- the next update would just redraw a fresh straight line
// through that same bar anyway. So if today's projection would land
// inside today's body, drawing genuinely stops there (the line freezes,
// left on the chart, never deleted) -- but the underlying origin/far
// tracking is left alone, so the roll-forward block above can still
// recognize the next genuinely clean touch point using this same origin
// and resume drawing immediately, rather than needing a whole new leg to
// start from scratch. A wick crossing the line while close holds on the
// correct side (the line sitting outside the body entirely) is a
// REACTION, not an intrusion.
//
// This block is also the ONLY place trendState flips away from bullish:
// while there's no line yet (just a pending origin from one touch point),
// the reference to break is a flat line at that origin price; once a real
// 2+ point line exists, the reference is its projected slope, same as
// before. Either way, a genuine close-through-the-reference break is what
// it actually means for this direction to have failed -- not some
// separately-recomputed pivot threshold that can drift around underneath
// an otherwise-healthy line.
if trendState == 1 and not na(bullOriginBar)
    bullHasLine      = trackingBull and not na(bullLine)
    bullSlope        = trackingBull and bullFarBar != bullOriginBar ? (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar) : 0.0
    bullProjectedNow = trackingBull ? bullFarPrice + bullSlope * (bar_index - bullFarBar) : bullOriginPrice
    bullBreakMargin  = atrVal * minBreakAtrMult + math.abs(bullSlope) * touchBars
    bullBodyTop      = math.max(open, close)
    bullBodyBottom   = math.min(open, close)
    bullIntrudesNow  = trackingBull and bullProjectedNow > bullBodyBottom and bullProjectedNow < bullBodyTop
    if close < bullProjectedNow - bullBreakMargin
        // Whatever was active in this direction -- a real line, or just a
        // pending single touch point that never earned a second one --
        // has now genuinely failed. Flip to bearish, seeded from the most
        // recent confirmed swing high, and only emit a tradeable break
        // signal if a real line actually existed to break.
        if bullHasLine
            if freezeExtendBars > 0
                line.set_xy2(bullLine, time + freezeExtendBars * timeframe.in_seconds() * 1000, bullProjectedNow + bullSlope * freezeExtendBars)
            bullBreak := true
            pendingShortActive := true
            pendingShortLevel  := bullProjectedNow
            pendingShortBar    := bar_index
            pendingShortTested := false
            if showLabels
                label.new(bar_index, close, text="TREND BREAK", style=label.style_label_down, color=color.new(color.red, 50), textcolor=color.white, size=size.small)
        trackingBull    := false
        bullLine        := na
        bullOriginBar   := na
        bullOriginTime  := na
        bullOriginPrice := na
        bullFarBar      := na
        bullFarTime     := na
        bullFarPrice    := na
        trendState      := -1
        bearOriginBar   := lastPivotHighBar
        bearOriginTime  := lastPivotHighTime
        bearOriginPrice := lastPivotHigh
        bearFarBar      := bearOriginBar
        bearFarTime     := bearOriginTime
        bearFarPrice    := bearOriginPrice
        bearIsDivergent := false
        trackingBear    := false
        bearLine        := na
        if showDebug
            label.new(bar_index, high, text="BREAK", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
            if not na(bearOriginTime)
                label.new(bearOriginTime, bearOriginPrice, text="H", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if bullIntrudesNow
        // A line is one continuous straight segment between two points --
        // there's no such thing as "skip drawing through just this one
        // bar" while still drawing the bars after it; the next update
        // would just redraw a fresh straight line from the same origin
        // through this same bar anyway. So this has to actually stop the
        // line, not pretend to skip past the problem. Unlike a real break,
        // though, the underlying origin/far tracking is left alone (only
        // drawing pauses) so the roll-forward block above can still
        // recognize the next genuinely clean touch point -- whether a
        // plain continuation or a divergent branch -- using this same
        // origin, and resume drawing immediately with a fresh line rather
        // than needing an entirely new leg to start from scratch.
        trackingBull := false
        bullLine     := na
        if showDebug
            label.new(bar_index, bullBodyBottom, text="CLIP", style=label.style_circle, color=color.new(color.gray, 40), textcolor=color.white, size=size.tiny)
    else if trackingBull
        if showReactions and low < bullProjectedNow and close >= bullProjectedNow
            label.new(bar_index, low, text="REACT", style=label.style_circle, color=color.new(bullColor, 40), textcolor=color.white, size=size.tiny)
        bullLineColor = bullIsDivergent ? bullDivergeColor : bullColor
        if na(bullLine)
            bullLine := line.new(bullOriginTime, bullOriginPrice, time, bullProjectedNow, xloc=xloc.bar_time, extend=extend.none, color=bullLineColor, width=2)
        else
            line.set_xy2(bullLine, time, bullProjectedNow)

if trendState == -1 and not na(bearOriginBar)
    bearHasLine      = trackingBear and not na(bearLine)
    bearSlope        = trackingBear and bearFarBar != bearOriginBar ? (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar) : 0.0
    bearProjectedNow = trackingBear ? bearFarPrice + bearSlope * (bar_index - bearFarBar) : bearOriginPrice
    bearBreakMargin  = atrVal * minBreakAtrMult + math.abs(bearSlope) * touchBars
    bearBodyTop      = math.max(open, close)
    bearBodyBottom   = math.min(open, close)
    bearIntrudesNow  = trackingBear and bearProjectedNow > bearBodyBottom and bearProjectedNow < bearBodyTop
    if close > bearProjectedNow + bearBreakMargin
        // See the symmetric comment in the bullish block above.
        if bearHasLine
            if freezeExtendBars > 0
                line.set_xy2(bearLine, time + freezeExtendBars * timeframe.in_seconds() * 1000, bearProjectedNow + bearSlope * freezeExtendBars)
            bearBreak := true
            pendingLongActive := true
            pendingLongLevel  := bearProjectedNow
            pendingLongBar    := bar_index
            pendingLongTested := false
            if showLabels
                label.new(bar_index, close, text="TREND BREAK", style=label.style_label_up, color=color.new(color.green, 50), textcolor=color.white, size=size.small)
        trackingBear    := false
        bearLine        := na
        bearOriginBar   := na
        bearOriginTime  := na
        bearOriginPrice := na
        bearFarBar      := na
        bearFarTime     := na
        bearFarPrice    := na
        trendState      := 1
        bullOriginBar   := lastPivotLowBar
        bullOriginTime  := lastPivotLowTime
        bullOriginPrice := lastPivotLow
        bullFarBar      := bullOriginBar
        bullFarTime     := bullOriginTime
        bullFarPrice    := bullOriginPrice
        bullIsDivergent := false
        trackingBull    := false
        bullLine        := na
        if showDebug
            label.new(bar_index, low, text="BREAK", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
            if not na(bullOriginTime)
                label.new(bullOriginTime, bullOriginPrice, text="L", xloc=xloc.bar_time, style=label.style_circle, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
    else if bearIntrudesNow
        trackingBear := false
        bearLine     := na
        if showDebug
            label.new(bar_index, bearBodyTop, text="CLIP", style=label.style_circle, color=color.new(color.gray, 40), textcolor=color.white, size=size.tiny)
    else if trackingBear
        if showReactions and high > bearProjectedNow and close <= bearProjectedNow
            label.new(bar_index, high, text="REACT", style=label.style_circle, color=color.new(bearColor, 40), textcolor=color.white, size=size.tiny)
        bearLineColor = bearIsDivergent ? bearDivergeColor : bearColor
        if na(bearLine)
            bearLine := line.new(bearOriginTime, bearOriginPrice, time, bearProjectedNow, xloc=xloc.bar_time, extend=extend.none, color=bearLineColor, width=2)
        else
            line.set_xy2(bearLine, time, bearProjectedNow)

// Backtest-confirmation watches: after a break, watch the broken level for
// up to backtestBars. If price comes back to test it (within
// backtestAtrMult x ATR) and then closes back away in the new direction,
// that's a confirmed entry. If price closes back through to the original
// side first, it's a fakeout and the watch is cancelled.
if pendingShortActive
    if bar_index - pendingShortBar > backtestBars
        pendingShortActive := false
    else if close > pendingShortLevel + atrVal * minBreakAtrMult
        pendingShortActive := false
        if showLabels
            label.new(bar_index, close, text="FAKEOUT", style=label.style_label_down, color=color.new(color.gray, 30), textcolor=color.white, size=size.small)
    else
        if not pendingShortTested and high > pendingShortLevel - atrVal * backtestAtrMult
            pendingShortTested := true
        if pendingShortTested and close < pendingShortLevel - atrVal * backtestAtrMult
            pendingShortActive := false
            confirmedShort := true
            if showLabels
                label.new(bar_index, high, text="CONFIRMED SHORT", style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.normal)

if pendingLongActive
    if bar_index - pendingLongBar > backtestBars
        pendingLongActive := false
    else if close < pendingLongLevel - atrVal * minBreakAtrMult
        pendingLongActive := false
        if showLabels
            label.new(bar_index, close, text="FAKEOUT", style=label.style_label_up, color=color.new(color.gray, 30), textcolor=color.white, size=size.small)
    else
        if not pendingLongTested and low < pendingLongLevel + atrVal * backtestAtrMult
            pendingLongTested := true
        if pendingLongTested and close > pendingLongLevel + atrVal * backtestAtrMult
            pendingLongActive := false
            confirmedLong := true
            if showLabels
                label.new(bar_index, low, text="CONFIRMED LONG", style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, size=size.normal)

// Live numeric readout of whichever line(s) are currently tracking --
// exact origin/far anchors and the resulting slope, so anchor placement
// can be verified precisely instead of estimated from chart pixels.
if showDebug and barstate.islast
    var table dbgTable = table.new(position.bottom_right, 2, 3, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)
    bullDbgSlope = trackingBull and not na(bullOriginBar) and bullFarBar != bullOriginBar ? (bullFarPrice - bullOriginPrice) / (bullFarBar - bullOriginBar) : na
    bearDbgSlope = trackingBear and not na(bearOriginBar) and bearFarBar != bearOriginBar ? (bearFarPrice - bearOriginPrice) / (bearFarBar - bearOriginBar) : na
    bullDbgText  = trackingBull and not na(bullOriginBar) ? "o(" + str.tostring(bullOriginBar) + ", " + str.tostring(bullOriginPrice, format.mintick) + ")  f(" + str.tostring(bullFarBar) + ", " + str.tostring(bullFarPrice, format.mintick) + ")  slope=" + str.tostring(bullDbgSlope, "#.####") + (bullIsDivergent ? "  [D]" : "") : "inactive"
    bearDbgText  = trackingBear and not na(bearOriginBar) ? "o(" + str.tostring(bearOriginBar) + ", " + str.tostring(bearOriginPrice, format.mintick) + ")  f(" + str.tostring(bearFarBar) + ", " + str.tostring(bearFarPrice, format.mintick) + ")  slope=" + str.tostring(bearDbgSlope, "#.####") + (bearIsDivergent ? "  [D]" : "") : "inactive"
    stateText    = trendState == 1 ? "BULL" : trendState == -1 ? "BEAR" : "none"
    table.cell(dbgTable, 0, 0, "State", text_color=color.white, bgcolor=color.new(color.blue, 60))
    table.cell(dbgTable, 1, 0, stateText, text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dbgTable, 0, 1, "Bull", text_color=color.white, bgcolor=color.new(color.green, 60))
    table.cell(dbgTable, 1, 1, bullDbgText, text_color=color.white, bgcolor=color.new(color.black, 15))
    table.cell(dbgTable, 0, 2, "Bear", text_color=color.white, bgcolor=color.new(color.red, 60))
    table.cell(dbgTable, 1, 2, bearDbgText, text_color=color.white, bgcolor=color.new(color.black, 15))

alertcondition(bullBreak, title="Uptrend Line Broken", message="Price closed below an ascending support trend line")
alertcondition(bearBreak, title="Downtrend Line Broken", message="Price closed above a descending resistance trend line")
alertcondition(confirmedLong, title="Confirmed Long (downtrend break + backtest hold)", message="A broken downtrend line was backtested and held -- confirmed long entry")
alertcondition(confirmedShort, title="Confirmed Short (uptrend break + backtest hold)", message="A broken uptrend line was backtested and held -- confirmed short entry")
