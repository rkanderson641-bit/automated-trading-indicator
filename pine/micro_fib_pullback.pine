//@version=6
indicator("Micro Fib Pullback Levels (ZigZag)", overlay=true, max_lines_count=500, max_labels_count=500)

// ---------------------------------------------------------------------------
// Inputs
// ---------------------------------------------------------------------------
atrLen         = input.int(14, "ATR length", minval=1, group="Swing Threshold")
thresholdMult  = input.float(1.5, "Minimum reversal to confirm a swing (x ATR)", minval=0.1, step=0.1, group="Swing Threshold")
showDebug      = input.bool(true, "Show debug markers at confirmed swing points", group="Debug")

atrVal    = ta.atr(atrLen)
threshold = atrVal * thresholdMult

// ---------------------------------------------------------------------------
// Standard ZigZag swing detector. A new pivot only confirms once price
// reverses from the current candidate extreme by at least `threshold`.
// This is the same technique most "auto Fibonacci" tools use: it avoids
// the whipsaw/invalidation problems of structure-break heuristics because
// a confirmed pivot can never be "un-confirmed" — it's a fact about price
// that already happened, not a live-updating guess.
//
// The fib is always drawn between the last two confirmed swing points
// (the most recently completed leg), redrawn only when a new pivot
// confirms — not every bar — so it stays stable between confirmations.
// ---------------------------------------------------------------------------
var string dir          = "up" // "up" = searching for a new HIGH pivot, "down" = searching for a new LOW pivot
var float  pivotVal      = na
var int    pivotBar      = na
var float  prevPivotVal  = na
var int    prevPivotBar  = na
var float  candidate     = na
var int    candidateBar  = na

var line  fibLn50   = na
var line  fibLn618  = na
var label fibLbl50  = na
var label fibLbl618 = na

justConfirmed = false

if na(pivotVal)
    pivotVal     := close
    pivotBar     := bar_index
    candidate    := close
    candidateBar := bar_index
else if dir == "up"
    if na(candidate) or high > candidate
        candidate    := high
        candidateBar := bar_index
    if candidate - low >= threshold
        prevPivotVal := pivotVal
        prevPivotBar := pivotBar
        pivotVal     := candidate
        pivotBar     := candidateBar
        dir          := "down"
        candidate    := low
        candidateBar := bar_index
        justConfirmed := true

        if showDebug
            label.new(pivotBar, pivotVal, text="PIVOT", style=label.style_label_down, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)
else
    if na(candidate) or low < candidate
        candidate    := low
        candidateBar := bar_index
    if high - candidate >= threshold
        prevPivotVal := pivotVal
        prevPivotBar := pivotBar
        pivotVal     := candidate
        pivotBar     := candidateBar
        dir          := "up"
        candidate    := high
        candidateBar := bar_index
        justConfirmed := true

        if showDebug
            label.new(pivotBar, pivotVal, text="PIVOT", style=label.style_label_up, color=color.new(color.orange, 50), textcolor=color.white, size=size.tiny)

// ---------------------------------------------------------------------------
// Draw the fib for the most recently completed leg (prevPivotVal -> pivotVal)
// whenever a new pivot has just confirmed.
// ---------------------------------------------------------------------------
// Only redraw on the exact bar a new pivot just confirmed.
if not na(prevPivotVal) and justConfirmed
    if not na(fibLn50)
        line.delete(fibLn50)
        line.delete(fibLn618)
        label.delete(fibLbl50)
        label.delete(fibLbl618)

    legColor = pivotVal > prevPivotVal ? color.green : color.red

    move   = pivotVal - prevPivotVal
    lvl50  = pivotVal - 0.5 * move
    lvl618 = pivotVal - 0.618 * move

    fibLn50   := line.new(bar_index, lvl50, bar_index + 1, lvl50, extend=extend.right, color=legColor, width=1, style=line.style_dashed)
    fibLn618  := line.new(bar_index, lvl618, bar_index + 1, lvl618, extend=extend.right, color=legColor, width=1, style=line.style_dashed)
    fibLbl50  := label.new(bar_index, lvl50, text="50.00% (" + str.tostring(lvl50, format.mintick) + ")", style=label.style_label_left, color=color.new(legColor, 80), textcolor=legColor, size=size.small)
    fibLbl618 := label.new(bar_index, lvl618, text="61.80% (" + str.tostring(lvl618, format.mintick) + ")", style=label.style_label_left, color=color.new(legColor, 80), textcolor=legColor, size=size.small)
